{
  "$schema": "https://tr.designtokens.org/format/",
  "colors": {
    "counter": {
      "$description": "Named palette for counter marker badges",
      "sage":       { "$value": "#7AAD8F", "$type": "color", "$description": "Sage green" },
      "mauve":      { "$value": "#BF85A8", "$type": "color", "$description": "Muted mauve" },
      "terracotta": { "$value": "#D47359", "$type": "color", "$description": "Warm terracotta" },
      "steel":      { "$value": "#6B9CBF", "$type": "color", "$description": "Cool steel blue" },
      "gold":       { "$value": "#D4A842", "$type": "color", "$description": "Warm gold" },
      "lavender":   { "$value": "#9C8FC4", "$type": "color", "$description": "Soft lavender" },
      "forest":     { "$value": "#6B8F5E", "$type": "color", "$description": "Deep forest green" },
      "rose":       { "$value": "#E8A6A6", "$type": "color", "$description": "Pale rose" },
      "slate":      { "$value": "#7A8FA6", "$type": "color", "$description": "Blue-grey slate" },
      "amber":      { "$value": "#C96B2E", "$type": "color", "$description": "Deep amber" },
      "plum":       { "$value": "#7A4F73", "$type": "color", "$description": "Dark plum (uses white text)" },
      "linen":      { "$value": "#C7B899", "$type": "color", "$description": "Warm linen" }
    },
    "status": {
      "$description": "Project status indicator colors",
      "notStarted": { "$value": "#8E8E93", "$type": "color", "$description": "iOS system secondary grey" },
      "inProgress": { "$value": "#007AFF", "$type": "color", "$description": "iOS system blue / accent" },
      "onHold":     { "$value": "#FF9500", "$type": "color", "$description": "iOS system orange" },
      "completed":  { "$value": "#34C759", "$type": "color", "$description": "iOS system green" }
    },
    "category": {
      "$description": "Glossary category badge colors",
      "basicStitches":    { "$value": "#FFCC00", "$type": "color", "$description": "Yellow — basic stitches" },
      "increasesDecreases": { "$value": "#FF9500", "$type": "color", "$description": "Orange — increases & decreases" },
      "castOnBindOff":    { "$value": "#34C759", "$type": "color", "$description": "Green — cast on & bind off" },
      "cables":           { "$value": "#AF52DE", "$type": "color", "$description": "Purple — cables" },
      "colorwork":        { "$value": "#FF2D55", "$type": "color", "$description": "Pink — colorwork" },
      "lace":             { "$value": "#32ADE6", "$type": "color", "$description": "Cyan — lace" },
      "default":          { "$value": "#007AFF", "$type": "color", "$description": "Blue — all other categories" }
    },
    "marker": {
      "$description": "Legacy marker color strings (used by note markers)",
      "blue":   { "$value": "#007AFF", "$type": "color" },
      "green":  { "$value": "#34C759", "$type": "color" },
      "red":    { "$value": "#FF3B30", "$type": "color" },
      "yellow": { "$value": "#FF9500", "$type": "color", "$description": "Rendered as orange for contrast" },
      "purple": { "$value": "#AF52DE", "$type": "color" }
    }
  },
  "typography": {
    "family": {
      "$description": "Typeface families. Both are Google Fonts — download .ttf files and add to Xcode project + Info.plist.",
      "display": { "$value": "Fraunces", "$type": "string", "$description": "Header / display font — used for titles and large text" },
      "body":    { "$value": "DM Sans",  "$type": "string", "$description": "Body / UI font — used for all interface text" }
    },
    "weight": {
      "$description": "Font weight names — Figma style strings. SwiftUI Font.Weight equivalents noted per token.",
      "regular":  { "$value": "Regular",   "$type": "string", "$description": "SwiftUI: .regular" },
      "semibold": { "$value": "SemiBold",  "$type": "string", "$description": "SwiftUI: .semibold  (DM Sans uses one word)" },
      "bold":     { "$value": "Bold",      "$type": "string", "$description": "SwiftUI: .bold" },
      "italic":   { "$value": "Italic",    "$type": "string", "$description": "Fraunces is an optical-size variable font — italic variant available" }
    },
    "size": {
      "$description": "Font size scale in points",
      "xs":   { "$value": 10, "$type": "number", "$description": "Smallest label text (monospaced PDF)" },
      "sm":   { "$value": 12, "$type": "number", "$description": "Caption / min reader size" },
      "base": { "$value": 14, "$type": "number", "$description": "Standard detail text" },
      "md":   { "$value": 16, "$type": "number", "$description": "Body / base reader font" },
      "lg":   { "$value": 18, "$type": "number", "$description": "Section headers" },
      "xl":   { "$value": 22, "$type": "number", "$description": "Tool tab icons / counter display" },
      "xxl":  { "$value": 36, "$type": "number", "$description": "Large display text" },
      "hero": { "$value": 48, "$type": "number", "$description": "Hero numbers (glossary detail)" }
    }
  },
  "spacing": {
    "$description": "Padding and gap values in points",
    "xs":   { "$value": 4,  "$type": "number" },
    "sm":   { "$value": 6,  "$type": "number" },
    "md":   { "$value": 8,  "$type": "number" },
    "lg":   { "$value": 12, "$type": "number" },
    "xl":   { "$value": 16, "$type": "number" },
    "xxl":  { "$value": 20, "$type": "number" },
    "xxxl": { "$value": 24, "$type": "number" },
    "max":  { "$value": 30, "$type": "number" }
  },
  "radius": {
    "$description": "Corner radius values in points",
    "xs": { "$value": 4,  "$type": "number", "$description": "Text highlights, small chips" },
    "sm": { "$value": 8,  "$type": "number", "$description": "Text fields, small interactive elements" },
    "md": { "$value": 10, "$type": "number", "$description": "Search bar" },
    "lg": { "$value": 12, "$type": "number", "$description": "Cards, buttons, backgrounds" }
  },
  "shadow": {
    "standard": {
      "opacity": { "$value": 0.2,  "$type": "number", "$description": "Shadow opacity (black)" },
      "radius":  { "$value": 4,    "$type": "number", "$description": "Shadow blur radius" },
      "y":       { "$value": 2,    "$type": "number", "$description": "Shadow vertical offset" }
    },
    "accent": {
      "opacity": { "$value": 0.35, "$type": "number", "$description": "Accent shadow opacity" },
      "radius":  { "$value": 12,   "$type": "number", "$description": "Accent shadow blur radius" },
      "y":       { "$value": 5,    "$type": "number", "$description": "Accent shadow vertical offset" }
    }
  }
}
